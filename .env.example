# Django
SECRET_KEY=your-secret-key-here-change-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database
MYSQL_ROOT_PASSWORD=rootpassword
MYSQL_DATABASE=fqxs
MYSQL_USER=fqxs_user
MYSQL_PASSWORD=fqxs_password
DATABASE_URL=mysql://fqxs_user:fqxs_password@mysql:3306/fqxs

# Redis
REDIS_URL=redis://redis:6379/0

# FastAPI
FASTAPI_URL=http://localhost:8001

# Frontend API base URL
# Local development example:
VITE_API_BASE_URL=http://localhost:8000/api

# Production example:
# VITE_API_BASE_URL=https://your-domain.example/api

# If frontend and backend are served from the same origin behind a reverse proxy:
# VITE_API_BASE_URL=/api

# LLM Configuration
# Set FASTAPI_MOCK_GENERATION=False to use real LLM API
FASTAPI_MOCK_GENERATION=True
FASTAPI_LLM_API_URL=https://api.openai.com/v1
FASTAPI_LLM_API_KEY=your-openai-api-key-here
FASTAPI_LLM_MODEL=gpt-3.5-turbo

# Alternative: Tongyi Qianwen (阿里通义千问)
# FASTAPI_LLM_API_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# FASTAPI_LLM_API_KEY=your-dashscope-api-key-here
# FASTAPI_LLM_MODEL=qwen-turbo

# Sentry (optional)
SENTRY_DSN=
ENVIRONMENT=development
